#!/usr/bin/env ruby
# frozen_string_literal: true

# Usage: build-release-notes [mud-cli-path]
#
# Reads Doc/RELEASES.md, extracts per-version sections, and renders HTML
# to Site/releases/ using the Mud CLI.
#
# The Mud CLI path defaults to /usr/local/bin/mud (the installed symlink).
# Override with the first argument for CI or non-standard installs.

require "fileutils"

RELEASES_PATH = "Doc/RELEASES.md"
OUTPUT_DIR = "Site/releases"

mud_cli = ARGV[0] || "/usr/local/bin/mud"

abort "#{RELEASES_PATH} not found" unless File.exist?(RELEASES_PATH)
abort "Mud CLI not found at #{mud_cli}" unless File.executable?(mud_cli)

content = File.read(RELEASES_PATH)

# Extract version sections (## vX.Y.Z ... up to next ## or EOF)
sections = content.scan(/^(## v\S+.*?)(?=^## |\z)/m)

FileUtils.mkdir_p(OUTPUT_DIR)

# Copy Doc/Assets/ → Site/releases/assets/ (lowercase)
assets_src = File.join(File.dirname(RELEASES_PATH), "Assets")
assets_dst = File.join(OUTPUT_DIR, "assets")
if Dir.exist?(assets_src)
  FileUtils.mkdir_p(assets_dst)
  Dir.glob(File.join(assets_src, "*")).each { |f| FileUtils.cp(f, assets_dst) }
end

def rewrite_asset_paths(html)
  html.gsub('src="Assets/', 'src="assets/')
end

sections.each do |match|
  section = match[0].strip
  version = section[/^## (v\S+)/, 1]
  next unless version

  # Promote the ## heading to # for the standalone page
  page = section.sub(/^## /, "# ")
  page += "\n\n---\n\n[All release notes](https://apps.josephpearson.org/mud/releases)\n"
  outfile = File.join(OUTPUT_DIR, "#{version}.html")
  IO.popen([mud_cli, "-u"], "r+") do |io|
    io.write(page)
    io.close_write
    File.write(outfile, rewrite_asset_paths(io.read))
  end
  puts "  #{outfile}"
end

# Full history
index_file = File.join(OUTPUT_DIR, "index.html")
IO.popen([mud_cli, "-u"], "r+") do |io|
  io.write(content)
  io.close_write
  File.write(index_file, rewrite_asset_paths(io.read))
end
puts "  #{index_file}"
